{
    "cleanUrls": false,
    "trailingSlash": false,
    "routes": [
        {
            "src": "/sitemap.xml",
            "dest": "/sitemap.xml"
        },
        {
            "src": "/sw.js",
            "dest": "/sw.js"
        },
        {
            "src": "/googled6e0f85472448f7b.html",
            "dest": "/googled6e0f85472448f7b.html"
        },
        {
            "src": "/(.*)\\.xml",
            "dest": "/$1.xml"
        },
        {
            "src": "/(.*)\\.html",
            "dest": "/$1.html"
        },
        {
            "src": "/(.*)\\.js",
            "dest": "/$1.js"
        },
        {
            "src": "/(.*)",
            "dest": "/$1"
        }
    ]
}